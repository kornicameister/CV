---
import { readFileSync } from 'fs';
import { join } from 'path';

interface Social {
  key: string;
  value: string;
  id?: string;
}

interface Props {
  firstName: string;
  lastName: string;
  position: string;
  photoUrl: string;
  social: Social[];
}

const { firstName, lastName, position, photoUrl, social } = Astro.props;

// Filter for GitHub and LinkedIn only
const displaySocial = social.filter(s =>
  s.key === 'github' || s.key === 'linkedin'
);

// Handle the photo URL - prepend base path if not already included
const baseUrl = import.meta.env.BASE_URL || '/';
const normalizedPhotoUrl = photoUrl.startsWith('./') ? photoUrl.slice(1) : photoUrl;
const fullPhotoUrl = normalizedPhotoUrl.startsWith(baseUrl) ? normalizedPhotoUrl : `${baseUrl}${normalizedPhotoUrl}`;

// Second avatar for hover effect
const baseUrlWithSlash = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const avatarDevUrl = `${baseUrlWithSlash}media/avatar-dev.png`;

// Read content seed for geometric pattern generation
let seed = 12345; // fallback
try {
  const seedPath = join(process.cwd(), 'src', 'data', 'content-seed.txt');
  const seedStr = readFileSync(seedPath, 'utf-8').trim();
  seed = parseInt(seedStr.substring(0, 8), 16);
} catch (e) {
  console.warn('Could not read content-seed.txt, using fallback seed');
}

// Seeded PRNG (Linear Congruential Generator)
class SeededRandom {
  private seed: number;

  constructor(seed: number) {
    this.seed = seed;
  }

  next(): number {
    this.seed = (this.seed * 1664525 + 1013904223) % 2147483648;
    return this.seed / 2147483648;
  }

  range(min: number, max: number): number {
    return min + this.next() * (max - min);
  }
}

const rng = new SeededRandom(seed);

// Generate geometric shapes
interface Shape {
  type: 'circle' | 'triangle' | 'square';
  x: number;
  y: number;
  size: number;
  rotation: number;
  opacity: number;
  color: string;
}

const shapes: Shape[] = [];
const shapeCount = 25;
const colors = ['#3b82f6', '#8b5cf6', '#ec4899', '#06b6d4', '#10b981', '#f59e0b', '#ef4444'];

for (let i = 0; i < shapeCount; i++) {
  const types: Array<'circle' | 'triangle' | 'square'> = ['circle', 'triangle', 'square'];
  shapes.push({
    type: types[Math.floor(rng.next() * types.length)],
    x: rng.range(-10, 110),
    y: rng.range(-10, 110),
    size: rng.range(100, 400),
    rotation: rng.range(0, 360),
    opacity: rng.range(0.15, 0.35),
    color: colors[Math.floor(rng.next() * colors.length)]
  });
}
---

<section id="hero" class="hero">
  <!-- Geometric pattern background -->
  <div class="hero-pattern">
    {shapes.map((shape, i) => (
      <div
        class={`shape shape-${shape.type}`}
        style={`
          left: ${shape.x}%;
          top: ${shape.y}%;
          width: ${shape.size}px;
          height: ${shape.size}px;
          transform: rotate(${shape.rotation}deg);
          opacity: ${shape.opacity};
          background-color: ${shape.color};
        `}
        data-shape-id={i}
      />
    ))}
  </div>

  <div class="hero-content">
    <div class="hero-photo-container" id="hero-photo-container">
      <img src={fullPhotoUrl} alt={`${firstName} ${lastName}`} class="hero-photo hero-photo-primary" />
      <img src={avatarDevUrl} alt={`${firstName} ${lastName} - Developer Avatar`} class="hero-photo hero-photo-secondary" />
    </div>
    <h1 class="hero-name gradient-text">
      <span class="name-real">{firstName} {lastName}</span>
      <span class="name-alias">kornicameister</span>
    </h1>
    <p class="hero-position">{position}</p>
    <div class="hero-social">
      {displaySocial.map(social => (
        <a
          href={social.key === 'github' ? `https://github.com/${social.value}` : `https://linkedin.com/in/${social.value}`}
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label={social.key}
        >
          {social.key === 'github' ? (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.840 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          ) : (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    z-index: 0;
  }

  .shape {
    position: absolute;
    pointer-events: none;
    will-change: transform;
    filter: blur(40px);
  }

  .shape-circle {
    border-radius: 50%;
  }

  .shape-triangle {
    clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
  }

  .shape-square {
    border-radius: 12px;
  }

  .hero-content {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero-photo-container {
    position: relative;
    width: 200px;
    height: 200px;
    margin: 0 auto 2rem;
  }

  .hero-photo {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    border: 6px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    position: absolute;
    top: 0;
    left: 0;
    transition: opacity 0.3s ease;
  }

  .hero-photo-primary {
    opacity: 1;
    z-index: 2;
  }

  .hero-photo-secondary {
    opacity: 0;
    z-index: 1;
  }

  .hero-photo-container:hover .hero-photo-primary {
    opacity: 0;
  }

  .hero-photo-container:hover .hero-photo-secondary {
    opacity: 1;
  }

  .hero-name {
    font-size: 4rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: white;
  }

  .name-real,
  .name-alias {
    transition: opacity 0.3s ease;
  }

  .name-real {
    opacity: 1;
  }

  .name-alias {
    opacity: 0;
    display: none;
  }

  .name-real.hidden {
    display: none;
  }

  .name-alias.visible {
    display: inline;
    opacity: 1;
  }


  .hero-position {
    font-size: 1.5rem;
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .hero-social {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .social-link {
    color: white;
    opacity: 0.9;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .social-link:hover {
    opacity: 1;
    transform: translateY(-3px);
  }

  @media (max-width: 640px) {
    .hero-photo-container {
      width: 150px;
      height: 150px;
    }

    .hero-photo {
      width: 150px;
      height: 150px;
    }

    .hero-name {
      font-size: 2.5rem;
    }

    .hero-position {
      font-size: 1.2rem;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const photoContainer = document.getElementById('hero-photo-container');
    const nameReal = document.querySelector('.name-real');
    const nameAlias = document.querySelector('.name-alias');

    if (photoContainer && nameReal && nameAlias) {
      photoContainer.addEventListener('mouseenter', () => {
        nameReal.classList.add('hidden');
        nameAlias.classList.add('visible');
      });

      photoContainer.addEventListener('mouseleave', () => {
        nameReal.classList.remove('hidden');
        nameAlias.classList.remove('visible');
      });
    }
  });
</script>
