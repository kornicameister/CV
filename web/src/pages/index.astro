---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import Certifications from '../components/Certifications.astro';
import Skills from '../components/Skills.astro';
import Education from '../components/Education.astro';
import cvData from '../data/cv.json';
---

<BaseLayout title={`${cvData.basic.firstName} ${cvData.basic.lastName} - CV`}>
  <Hero
    firstName={cvData.basic.firstName}
    lastName={cvData.basic.lastName}
    position={cvData.basic.position}
    photoUrl={cvData.basic.photoUrl}
    social={cvData.social}
  />
  <Experience entries={cvData.experience} />
  <Certifications certs={cvData.cert} />
  <Skills skills={cvData.skill} />
  <Education entries={cvData.education} />
</BaseLayout>
